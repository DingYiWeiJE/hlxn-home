generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NewsStatus {
  DRAFT
  PUBLISHED
}

enum NewsLocale {
  zh
  en
}

model News {
  id            String     @id @default(cuid())
  title         String
  slug          String
  locale        NewsLocale
  summary       String?
  coverImage    String?
  coverImageAlt String?

  content       Json
  contentText   String?    @db.Text

  authorName    String?
  status        NewsStatus @default(DRAFT)
  isFeatured    Boolean    @default(false)

  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?

  @@unique([slug, locale])
  @@index([locale, status, publishedAt])
  @@index([status, publishedAt])
  @@index([deletedAt])
  @@index([isFeatured])
}

model MediaAsset {
  id           String   @id @default(cuid())
  url          String   @unique
  relativePath String   @unique
  filename     String
  originalName String?
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  createdAt    DateTime @default(now())
  deletedAt    DateTime?

  @@index([deletedAt])
}
